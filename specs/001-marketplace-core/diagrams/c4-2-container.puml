@startuml c4-2-container
' ShopFlow — C4 Level 2: Container (프론트 제어 MVC + 백엔드 REST)
!include <C4/C4_Container>

title ShopFlow — C4 컨테이너 (Level 2) · 프론트 제어 MVC + REST 리포지토리 백엔드 (ADR-0011)

Person(buyer, "구매자")
Person(seller, "판매자")
System_Ext(pg, "결제 게이트웨이", "모의(MVP) / 실 PSP(후속)")

System_Boundary(sf, "ShopFlow") {
  Container(femvc, "프론트 제어 웹 (MVC)", "Java 21, Spring MVC + Thymeleaf", "화면 렌더·폼·세션·플로우 제어(BFF). 백엔드 REST API 호출")
  Container(api, "백엔드 REST API", "Spring Boot, Spring Data REST + 커스텀 REST 컨트롤러, Spring Security", "6개 컨텍스트. 애그리거트 CRUD는 REST 리포지토리, 도메인 연산은 커스텀 REST")
  Container(sched, "스케줄러", "Spring @Scheduled (백엔드 내 실행)", "재고 선점 TTL 만료 스윕")
  ContainerDb(db, "관계형 DB", "PostgreSQL 16", "컨텍스트별 스키마. 경계 넘는 하드 FK 없음. Flyway")
}

Rel(buyer, femvc, "탐색·장바구니·결제·주문 조회", "HTTPS")
Rel(seller, femvc, "상품·재고 관리·배송 전이", "HTTPS")
Rel(femvc, api, "REST 호출(리소스 CRUD + 도메인 연산)", "HTTPS/JSON")
Rel(api, db, "읽기/쓰기 (트랜잭션)", "JDBC")
Rel(sched, db, "만료 선점 해제", "JDBC")
Rel(api, pg, "결제 승인 요청(멱등키)", "HTTPS")

note as N1
  현재는 모듈러 모놀리스(같은 배포 단위 내 프론트 제어 MVC + 백엔드 REST 모듈).
  목표(ADR-0010): 프론트 제어 웹과 각 컨텍스트를 별도 인스턴스로 분리, 이벤트/API 결합.
end note

SHOW_LEGEND()
@enduml
